rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds[request.auth.uid] == true;
    }

    match /rooms/{roomId} {
      // Cho phép đọc để tìm phòng qua invite code (query by inviteCodeLower)
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Thành viên cập nhật thông tin phòng; người join cập nhật memberIds
      allow update: if request.auth != null && (
        resource.data.memberIds[request.auth.uid] == true ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
      );

      // Members subcollection: user tự ghi doc của mình (để join), members đọc tất cả
      match /members/{memberId} {
        allow read: if request.auth != null && isMember(roomId);
        allow write: if request.auth != null && (
          memberId == request.auth.uid || isMember(roomId)
        );
      }

      // Các subcollection khác: chỉ members
      match /{sub}/{docId} {
        allow read, write: if request.auth != null && isMember(roomId);
      }
      match /{sub}/{docId}/{rest=**} {
        allow read, write: if request.auth != null && isMember(roomId);
      }
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
